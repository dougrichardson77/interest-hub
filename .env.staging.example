APP_ENV=staging
APP_VERSION=0.1.0
MIN_CLIENT_VERSION=1.0.0
YOUTUBE_API_KEY=your_youtube_data_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
PORT=4173
HOST=0.0.0.0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX_REQUESTS=20
JSON_BODY_LIMIT_BYTES=65536
CORS_ORIGIN_ALLOWLIST=https://staging.yourdomain.com
REFRESH_EVERY_HOURS=6
YOUTUBE_PUBLISHED_AFTER_DAYS=180
YOUTUBE_MAX_RESULTS_PER_QUERY=20
AUTO_REFRESH=false
